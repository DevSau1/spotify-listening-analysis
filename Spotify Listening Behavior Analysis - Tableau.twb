    <dashboard name='Understanding Listening Patterns' type='storyboard'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#000000' fontname='Benton Sans Book'>Understanding Listening Patterns</run>
          </formatted-text>
        </title>
      </layout-options>
      <style>
        <style-rule element='story-point-caption'>
          <format attr='width' value='513' />
        </style-rule>
      </style>
      <size maxheight='964' maxwidth='1016' minheight='964' minwidth='1016' />
      <zones>
        <zone h='100000' id='2' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='98340' id='1' param='vert' removable='false' type-v2='layout-flow' w='98426' x='787' y='830'>
            <zone h='3216' id='3' type-v2='title' w='98426' x='787' y='830' />
            <zone fixed-size='149' h='15456' id='4' is-fixed='true' paired-zone-id='5' removable='false' type-v2='flipboard-nav' w='98426' x='787' y='4046' />
            <zone h='79668' id='5' paired-zone-id='4' removable='false' type-v2='flipboard' w='98426' x='787' y='19502'>
              <flipboard active-id='1' nav-type='caption' show-nav-arrows='true'>
                <story-points>
                  <story-point caption='Analysis of 33K+ listening records shows clear variation in listening behavior by time of day, with peak activity occurring in the evening hours.' captured-sheet='Spotify Listening Behavior Analysis' id='1' />
                  <story-point caption='Listening activity peaks between approximately 5 PM and 9 PM, indicating that I most engaged during evening hours. Midday listening is significantly lower, this shows different user intent throughout the day. ' captured-sheet='Top Listening Hours' id='2' />
                  <story-point caption='Clustering analysis reveals three primary listening behaviors:&#10;&#10;- Quick skips (low engagement) - Cluster 0 (Blue)&#10;- Late-night listening sessions - Cluster 1 (White)&#10;- Full listening sessions (high engagement) - Cluster 2 (Green)' captured-sheet='Listening Behavior' id='3'>
                    <capturedDeltas>
                      <worksheet name='Listening Behavior'>
                        <selection-collection />
                      </worksheet>
                    </capturedDeltas>
                  </story-point>
                  <story-point caption='Product Strategy Next Steps &#10;&#10;1. Targeted Music Discovery&#10;&#10;2. Monetazation from highest listening hours' captured-sheet='Opportunites for Spotify' id='4' />
                </story-points>
              </flipboard>
            </zone>
